{
    "id": "org.gnome.Decibels",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.node24",
        "org.freedesktop.Sdk.Extension.typescript"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/node24/bin:/usr/lib/sdk/typescript/bin"
    },
    "command": "org.gnome.Decibels",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--env=GJS_DISABLE_JIT=1"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "decibels",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/decibels/49/decibels-49.0.tar.xz",
                    "sha256": "29b79ba2e2967e69141e39f0ad2c677e38fe3ffb9fba0fa5c7531f94d3f673ca",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "decibels",
                        "is-important": true
                    }
                }
            ]
        }
    ]
}
